# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://rastera:password@localhost:5432/rastera_health"

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET="change-me-to-a-secure-256-bit-random-string"
JWT_REFRESH_SECRET="change-me-to-a-different-secure-256-bit-random-string"

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000"

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=debug

# ── Notifications (Production) ────────────────────────────────────────────────
